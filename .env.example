# Copy this file to .env and fill in your EmailJS credentials
# See src/utils/emailjs.js for the full setup guide

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Optional: separate template for download requests (uses same template if not set)
# VITE_EMAILJS_TEMPLATE_DOWNLOAD_ID=template_yyyyyyy
